# Autonomous Database (used by database.py and setup_service)
ADB_WALLET_DIR=wallet
ADB_POOL_MIN=1
ADB_POOL_MAX=10
ADB_POOL_INCREMENT=1
DB_RUNTIME_CONFIG_PATH=data/runtime/db_connection.json

# Security (JWT - used by core/security.py)
SECRET_KEY=mi-secret-key-super-segura-cambiar-en-produccion-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (used by main.py)
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:3000","http://127.0.0.1:3000"]

# Logging (optional - used by core/logging_config.py, default INFO)
LOG_LEVEL=INFO

# Core app runtime
APP_NAME=AI Document Analyzer
API_PREFIX=/api
TRACE=true

# OCI / GenAI / Gemini
OCI_CONFIG_PATH=keys/config

# Runtime directories
DOCS_SOURCE_DIR=data/docs
STAGING_DIR=data/staging
EXTRACTED_DIR=data/extracted
PAGE_IMAGE_DIR=data/page_images
UPLOAD_DIR=data/uploads
USER_RUNTIME_SCOPE=global
